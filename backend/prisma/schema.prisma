// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum InputType {
  TEXT
  IMAGE
}

model UserAccount { // for email and stuff firebase is managing it
  firebaseUID  String    @id
  displayName  String
  history      History[]
}

model ProblemSubmission {
  id             String        @id @default(uuid())
  inputMode      InputType
  category       String
  type           String? // for statistics (multiple different subtypes)
  text           String
  createdAt      DateTime      @default(now())
  history        History[]
}

model History {
  userID        String
  submissionID  String
  createdAt     DateTime          @default(now())

  user          UserAccount       @relation(fields: [userID], references: [firebaseUID])
  submission    ProblemSubmission @relation(fields: [submissionID], references: [id])
  @@id([userID, submissionID])
}